
{
  "entities": {
    "UserRole": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserRole",
      "type": "object",
      "description": "Associates an internal application user ID with a specific role, used for access control (RBAC) within the Express Phone system.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "role", "createdAt", "updatedAt"]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Represents a hierarchical category for products (e.g., Spare Parts -> Screens -> iPhone Screens).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "The name of the category." },
        "parentId": { "type": "string", "description": "The ID of the parent category (null for root)." },
        "path": { "type": "string", "description": "Materialized path for easy querying (e.g., /spare-parts/screens)." },
        "level": { "type": "number", "description": "Nesting level (0 for root)." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdAt", "updatedAt"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a physical product or service item available for sale or used in repairs.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "categoryId": { "type": "string", "description": "Reference to the hierarchical Category." },
        "categoryName": { "type": "string", "description": "Denormalized category name for display." },
        "categoryPath": { "type": "string", "description": "Full path of categories for statistics." },
        "quantity": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "salePrice": { "type": "number" },
        "repairPrice": { "type": "number" },
        "productCode": { "type": "string" },
        "minStockQuantity": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "categoryId", "quantity", "salePrice", "productCode", "createdAt", "updatedAt"]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer of the shop.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "debt": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone", "createdAt", "updatedAt"]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "generatedByUserId": { "type": "string" }
      },
      "required": ["id", "customerId", "totalAmount", "paidAmount", "createdAt", "generatedByUserId"]
    },
    "Repair": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Repair",
      "type": "object",
      "description": "Legacy service requests mapped to repairs.",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "phoneType": { "type": "string" },
        "status": { "type": "string" },
        "finalCost": { "type": "number" },
        "receivedDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "clientName", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/user_roles/{userId}", "definition": { "entityName": "UserRole" } },
      { "path": "/categories/{categoryId}", "definition": { "entityName": "Category" } },
      { "path": "/products/{productId}", "definition": { "entityName": "Product" } },
      { "path": "/customers/{customerId}", "definition": { "entityName": "Customer" } },
      { "path": "/invoices/{invoiceId}", "definition": { "entityName": "Invoice" } },
      { "path": "/repairs/{repairId}", "definition": { "entityName": "Repair" } }
    ]
  }
}
