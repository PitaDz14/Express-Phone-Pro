rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/user_roles/$(request.auth.uid)) && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isWorker() {
      return hasRole('Worker');
    }

    function isAuthorizedStaff() {
      return isSignedIn() && (isAdmin() || isWorker());
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /user_roles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && request.resource.data.userId == userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read, write: if isAuthorizedStaff();
    }

    match /products/{productId} {
      allow read, write: if isAuthorizedStaff();
    }

    match /customers/{customerId} {
      allow read, write: if isAuthorizedStaff();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthorizedStaff();
      allow create: if isAuthorizedStaff() && request.resource.data.generatedByUserId == request.auth.uid;
      allow update, delete: if isAdmin() || (resource != null && resource.data.generatedByUserId == request.auth.uid);

      match /items/{invoiceItemId} {
        allow read: if isAuthorizedStaff();
        allow create: if isAuthorizedStaff();
        allow update, delete: if isAdmin() || (resource != null && resource.data.generatedByUserId == request.auth.uid);
      }
    }

    match /repairs/{repairId} {
      allow read, write: if isAuthorizedStaff();
    }

    match /audit_logs/{auditLogId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
