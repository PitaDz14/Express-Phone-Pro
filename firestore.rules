rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * EXPRESS PHONE SECURITY RULES - PROTOTYPING MODE
     * 
     * Core Philosophy:
     * This ruleset implements a robust Role-Based Access Control (RBAC) system for the Express Phone 
     * shop. It distinguishes between 'Admin' and 'Worker' roles to manage inventory, customers, 
     * and financial transactions.
     * 
     * Data Structure:
     * - /user_roles/{userId}: Maps Firebase Auth UIDs to application roles.
     * - /products, /customers, /categories: Flat, top-level collections.
     * - /invoices: Hierarchical structure containing items and payments as subcollections.
     * - /audit_logs: Restricted top-level collection for system activity.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated via Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Fetches the role of the currently authenticated user from the user_roles collection. */
    function getRole() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role;
    }

    /** @description Checks if the user has a specific role assigned. */
    function hasRole(role) {
      return isSignedIn() && getRole() == role;
    }

    /** @description Verifies if the user is an administrator. */
    function isAdmin() {
      return hasRole('Admin');
    }

    /** @description Verifies if the user is a shop worker. */
    function isWorker() {
      return hasRole('Worker');
    }

    /** @description Checks if the user is part of the authorized shop staff (Admin or Worker). */
    function isAuthorizedStaff() {
      return isAdmin() || isWorker();
    }

    /** @description Checks if the user's UID matches the provided userId (Path-based ownership). */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Verifies ownership for existing documents during update/delete. */
    function isExistingOwner(ownerIdField) {
      return resource != null && request.auth.uid == ownerIdField;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for managing User Roles. Admins can manage all; users can read their own.
     */
    match /user_roles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Hierarchical categories for products.
     */
    match /categories/{categoryId} {
      allow get, list: if isAuthorizedStaff();
      allow create, update, delete: if isAuthorizedStaff();
    }

    /**
     * @description Products inventory.
     */
    match /products/{productId} {
      allow get, list: if isAuthorizedStaff();
      allow create: if isAuthorizedStaff();
      allow update, delete: if isAuthorizedStaff() && resource != null;
    }

    /**
     * @description Customer records.
     */
    match /customers/{customerId} {
      allow get, list: if isAuthorizedStaff();
      allow create: if isAuthorizedStaff();
      allow update, delete: if isAuthorizedStaff() && resource != null;
    }

    /**
     * @description Invoices for sales.
     */
    match /invoices/{invoiceId} {
      allow get, list: if isAuthorizedStaff();
      allow create: if isAuthorizedStaff() && request.resource.data.generatedByUserId == request.auth.uid;
      allow update, delete: if (isAdmin() || isExistingOwner(resource.data.generatedByUserId)) && resource != null;

      match /items/{invoiceItemId} {
        allow get, list: if isAuthorizedStaff();
        allow create: if isAuthorizedStaff() && request.resource.data.generatedByUserId == request.auth.uid;
        allow update, delete: if (isAdmin() || isExistingOwner(resource.data.generatedByUserId)) && resource != null;
      }

      match /payments/{paymentId} {
        allow get, list: if isAuthorizedStaff();
        allow create: if isAuthorizedStaff() && request.resource.data.recordedByUserId == request.auth.uid;
        allow update, delete: if (isAdmin() || isExistingOwner(resource.data.recordedByUserId)) && resource != null;
      }
    }

    /**
     * @description Audit logs for tracking sensitive system actions.
     */
    match /audit_logs/{auditLogId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}